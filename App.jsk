import React, { useState, useEffect, useRef, useMemo, useCallback } from 'react';
import { RotateCcw, Keyboard, Clock, Activity, Target, AlertCircle, AlertTriangle, Settings, Flame, Volume2, VolumeX, Trophy, Award } from 'lucide-react';

// --- Dictionary & Utilities ---
const DICTIONARY = [
  "the", "be", "to", "of", "and", "a", "in", "that", "have", "I", "it", "for", "not", "on", 
  "with", "he", "as", "you", "do", "at", "this", "but", "his", "by", "from", "they", "we", 
  "say", "her", "she", "or", "an", "will", "my", "one", "all", "would", "there", "their", 
  "what", "so", "up", "out", "if", "about", "who", "get", "which", "go", "me", "when", 
  "make", "can", "like", "time", "no", "just", "him", "know", "take", "people", "into", 
  "year", "your", "good", "some", "could", "them", "see", "other", "than", "then", "now", 
  "look", "only", "come", "its", "over", "think", "also", "back", "after", "use", "two", 
  "how", "our", "work", "first", "well", "way", "even", "new", "want", "because", "any", 
  "these", "give", "day", "most", "us", "is", "are", "was", "were", "been", "being", "has",
  "had", "does", "did", "going", "many", "much", "more", "life", "world", "between", "each",
  "program", "developer", "experience", "beautiful", "important", "children", "different"
];

const PUNCTUATION = [",", ".", "?", "!", ";", ":", '""'];

const ALL_ACHIEVEMENTS = [
  // Visible Achievements
  { id: 'Speed Star 🌟', title: 'Speed Star', icon: '🌟', desc: 'Reach 100 WPM', hidden: false },
  { id: 'Perfect Accuracy 🎯', title: 'Perfect Accuracy', icon: '🎯', desc: 'Finish a test with 100% accuracy', hidden: false },
  { id: 'Combo Master ⚡', title: 'Combo Master', icon: '⚡', desc: 'Reach a 50 perfect word streak', hidden: false },
  { id: 'New High Score! 🏆', title: 'New High Score!', icon: '🏆', desc: 'Beat your personal best', hidden: false },
  { id: 'Marathon Runner 🏃', title: 'Marathon Runner', icon: '🏃', desc: 'Complete a 120-second test', hidden: false },
  { id: 'Punctuation Pedant 📝', title: 'Punctuation Pedant', icon: '📝', desc: 'Complete a punctuation mode test', hidden: false },
  { id: 'Number Cruncher 🔢', title: 'Number Cruncher', icon: '🔢', desc: 'Complete a numbers mode test', hidden: false },
  { id: 'Hardcore 💀', title: 'Hardcore', icon: '💀', desc: 'Complete a hard mode test', hidden: false },
  
  // Secret / Easter Egg Achievements
  { id: 'Sonic Speed 🦔', title: 'Sonic Speed', icon: '🦔', desc: 'Reach a blistering 120+ WPM', hidden: true },
  { id: 'Slow & Steady 🐢', title: 'Slow & Steady', icon: '🐢', desc: 'Finish with 100% accuracy but under 20 WPM', hidden: true },
  { id: 'Code Wizard 🧙‍♂️', title: 'Code Wizard', icon: '🧙‍♂️', desc: 'Correctly type "developer"', hidden: true },
  { id: 'Do a barrel roll 🛩️', title: 'Barrel Roll', icon: '🛩️', desc: 'Type "barrel"', hidden: true },
  { id: 'Caffeine Rush ☕', title: 'Caffeine Rush', icon: '☕', desc: 'Type "coffee"', hidden: true },
  { id: 'The Answer 🌌', title: 'The Answer', icon: '🌌', desc: 'Type "42"', hidden: true },
  { id: 'Back to the 80s 📼', title: 'Back to the 80s', icon: '📼', desc: 'Activate Retro mode', hidden: true },
  { id: 'Matrix Hacker 🕶️', title: 'Matrix Hacker', icon: '🕶️', desc: 'Discover the Matrix theme by typing "matrix"', hidden: true },
  { id: 'Backspace Abuser ⌨️', title: 'Backspace Abuser', icon: '⌨️', desc: 'Use backspace over 50 times in one test', hidden: true },
  { id: 'Stop Poking Me 😵', title: 'Stop Poking Me', icon: '😵', desc: 'Annoy the mascot by clicking them repeatedly', hidden: true },
  { id: 'Night Owl 🦉', title: 'Night Owl', icon: '🦉', desc: 'Complete a test between 12 AM and 4 AM', hidden: true }
];

const generateWords = (count, mode) => {
  return Array.from({ length: count }, () => {
    let word = "";
    if (mode === 'numbers') {
      word = Math.floor(Math.random() * 10000).toString();
    } else if (mode === 'hard') {
      const longWords = DICTIONARY.filter(w => w.length >= 6);
      word = longWords[Math.floor(Math.random() * longWords.length)];
    } else {
      word = DICTIONARY[Math.floor(Math.random() * DICTIONARY.length)];
      if (mode === 'punctuation') {
        if (Math.random() > 0.7) word = word.charAt(0).toUpperCase() + word.slice(1);
        if (Math.random() > 0.7) word += PUNCTUATION[Math.floor(Math.random() * PUNCTUATION.length)];
        if (Math.random() > 0.95) word = `"${word}"`;
      }
    }
    return word;
  });
};

// --- Audio System (Web Audio API) ---
const audioCtx = typeof window !== 'undefined' ? new (window.AudioContext || window.webkitAudioContext)() : null;
const playSound = (type) => {
  if (!audioCtx) return;
  if (audioCtx.state === 'suspended') audioCtx.resume();
  
  const osc = audioCtx.createOscillator();
  const gainNode = audioCtx.createGain();
  osc.connect(gainNode);
  gainNode.connect(audioCtx.destination);
  
  if (type === 'type') {
    osc.type = 'sine';
    osc.frequency.setValueAtTime(600, audioCtx.currentTime);
    osc.frequency.exponentialRampToValueAtTime(300, audioCtx.currentTime + 0.05);
    gainNode.gain.setValueAtTime(0.1, audioCtx.currentTime);
    gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.05);
    osc.start();
    osc.stop(audioCtx.currentTime + 0.05);
  } else if (type === 'error') {
    osc.type = 'sawtooth';
    osc.frequency.setValueAtTime(150, audioCtx.currentTime);
    gainNode.gain.setValueAtTime(0.1, audioCtx.currentTime);
    gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.1);
    osc.start();
    osc.stop(audioCtx.currentTime + 0.1);
  } else if (type === 'mascot') {
    osc.type = 'square';
    osc.frequency.setValueAtTime(400, audioCtx.currentTime);
    osc.frequency.exponentialRampToValueAtTime(200, audioCtx.currentTime + 0.1);
    gainNode.gain.setValueAtTime(0.05, audioCtx.currentTime);
    gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.1);
    osc.start();
    osc.stop(audioCtx.currentTime + 0.1);
  }
};

// --- Subcomponents ---
const Caret = ({ color }) => (
  <span className={`absolute -left-[2px] top-[10%] bottom-[10%] w-[3px] animate-pulse rounded-full z-10 ${color}`}></span>
);

const TimelineChart = ({ data, themeColors }) => {
  if (!data || data.length === 0) return null;
  const width = 800;
  const height = 160;
  const padding = 20;
  
  const maxWpm = Math.max(...data.map(d => d.wpm), 50); 
  const minWpm = 0;
  
  const getX = (index) => padding + (index / (data.length - 1 || 1)) * (width - padding * 2);
  const getY = (wpm) => height - padding - ((wpm - minWpm) / (maxWpm - minWpm)) * (height - padding * 2);

  const points = data.map((d, i) => `${getX(i)},${getY(d.wpm)}`).join(' L ');
  const pathD = `M ${getX(0)},${height} L ${points} L ${getX(data.length - 1)},${height} Z`;
  const lineD = `M ${points}`;

  return (
    <div className={`w-full max-w-4xl rounded-xl p-6 border relative ${themeColors.panelBg} ${themeColors.border}`}>
      <h3 className={`text-sm font-medium mb-4 absolute top-4 left-6 uppercase tracking-wider ${themeColors.textMuted}`}>WPM Timeline</h3>
      <svg viewBox={`0 0 ${width} ${height}`} className="w-full h-full overflow-visible mt-4">
        <defs>
          <linearGradient id="chartGradient" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stopColor={themeColors.accentRaw} stopOpacity="0.2" />
            <stop offset="100%" stopColor={themeColors.accentRaw} stopOpacity="0" />
          </linearGradient>
        </defs>
        
        {[0, 0.5, 1].map(ratio => (
          <line 
            key={ratio} x1={padding} y1={padding + (height - padding * 2) * ratio} x2={width - padding} y2={padding + (height - padding * 2) * ratio} 
            stroke="rgba(150,150,150,0.1)" strokeWidth="2" strokeDasharray="4 4"
          />
        ))}

        <path d={pathD} fill="url(#chartGradient)" />
        <path d={lineD} fill="none" stroke={themeColors.accentRaw} strokeWidth="3" strokeLinecap="round" strokeLinejoin="round" />
        
        {data.map((d, i) => (
          <circle key={i} cx={getX(i)} cy={getY(d.wpm)} r="4" fill={themeColors.bgRaw} stroke={themeColors.accentRaw} strokeWidth="2" />
        ))}
      </svg>
    </div>
  );
};

const Speedometer = ({ wpm, themeColors }) => {
  const maxWpm = 120;
  const clampedWpm = Math.min(wpm, maxWpm);
  const percentage = clampedWpm / maxWpm;
  const radius = 35;
  const circumference = Math.PI * radius; 
  const dashoffset = circumference * (1 - percentage);

  return (
    <div className="relative flex flex-col items-center justify-end h-16 w-32 overflow-hidden">
      <svg className="absolute top-0 w-full h-full" viewBox="0 0 100 50">
        <path d="M 15 45 A 35 35 0 0 1 85 45" fill="none" stroke="currentColor" strokeWidth="8" className={`${themeColors.text} opacity-20`} strokeLinecap="round" />
        <path d="M 15 45 A 35 35 0 0 1 85 45" fill="none" stroke={themeColors.accentRaw} strokeWidth="8" strokeDasharray={circumference} strokeDashoffset={dashoffset} className="transition-all duration-300 ease-out" strokeLinecap="round" />
      </svg>
      <div className="absolute bottom-0 flex flex-col items-center translate-y-1">
        <span className={`text-xl font-bold font-mono ${themeColors.accent}`}>{wpm}</span>
      </div>
    </div>
  );
};

const Mascot = ({ combo, wpm, status, themeColors, onClick, clickCount }) => {
  let message = "Ready, set, type!";
  let emotion = "👾";
  
  if (clickCount >= 10) {
    emotion = "😵";
    message = "Ouch! Stop poking me!";
  } else if (status === 'finished') {
    emotion = wpm > 100 ? "🔥" : wpm > 80 ? "😎" : "🎉";
    message = wpm > 100 ? "Godlike typing!" : wpm > 80 ? "Legendary speed!" : "Great job!";
  } else if (status === 'running') {
    if (combo > 20) { emotion = "🔥"; message = "UNSTOPPABLE!"; }
    else if (combo > 10) { emotion = "⚡"; message = "You're on fire!"; }
    else if (combo > 5) { emotion = "👀"; message = "Nice streak!"; }
    else { emotion = "👾"; message = "Keep it up..."; }
  }

  return (
    <div className={`fixed bottom-6 right-6 flex items-end gap-3 transition-all duration-500 z-50 ${status === 'idle' ? 'opacity-30' : 'opacity-100'} hover:opacity-100`}>
      <div className={`px-4 py-2 rounded-2xl rounded-br-none ${themeColors.panelBg} ${themeColors.border} border shadow-lg text-sm font-bold ${themeColors.textBright} animate-bounce`}>
        {message}
      </div>
      <div 
        onClick={onClick}
        className={`w-14 h-14 rounded-full ${themeColors.panelBg} border-2 ${themeColors.border} flex items-center justify-center text-3xl shadow-xl bg-opacity-90 select-none cursor-pointer hover:scale-110 active:scale-90 transition-transform ${clickCount >= 10 ? 'animate-[shake_0.5s_infinite]' : ''}`}
      >
        {emotion}
      </div>
    </div>
  );
};

// --- Theme Definitions ---
